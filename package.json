{
  "name": "@itsjustanks/heroui-vue",
  "version": "1.0.2",
  "description": "A faithful Vue 3 port of HeroUI v3 — the full compound-component API, styled by @heroui/styles, built on reka-ui.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsjustanks/heroui-vue.git"
  },
  "homepage": "https://github.com/itsjustanks/heroui-vue#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3",
    "heroui",
    "components",
    "ui",
    "design-system",
    "reka-ui"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/heroui-vue.js",
  "module": "./dist/heroui-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/heroui-vue.js"
    },
    "./styles.css": "./dist/heroui-vue.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "type-check": "vue-tsc --noEmit",
    "type-check:pro": "vue-tsc -p pro/tsconfig.json --noEmit",
    "maintain": "node scripts/maintain.mjs",
    "port:component": "node scripts/port-react-component.mjs",
    "extract:oss-manifest": "node scripts/extract-oss-manifest.mjs",
    "extract:pro-manifest": "node scripts/extract-pro-manifest.mjs",
    "check:parity": "node scripts/check-parity.mjs",
    "check:upstream": "node scripts/check-upstream.mjs",
    "check:coverage": "node scripts/check-coverage.mjs",
    "check:variant-props": "node scripts/check-variant-props.mjs",
    "check:bem-drift": "node scripts/check-bem-drift.mjs"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@heroui/styles": "^3.0.5",
    "@vueuse/core": "^12.8.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^2.5.5",
    "vue-sonner": "^1.2.1"
  },
  "devDependencies": {
    "@heroui/react": "^3.0.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "typescript": "~5.7.3",
    "vite": "^8.0.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
